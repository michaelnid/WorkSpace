# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mike_workspace
DB_USER=mike_app
DB_PASSWORD=

# Encryption
ENCRYPTION_KEY=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# auto = nur bei HTTPS secure setzen, true/false = erzwingen
COOKIE_SECURE=auto

# Server
PORT=3000
NODE_ENV=production

# Update (GitHub Releases)
UPDATE_URL=https://api.github.com/repos/michaelnid/WorkSpace
UPDATE_REQUIRE_HASH=true

# Plugin-Katalog (GitHub Pages)
PLUGIN_URL=https://michaelnid.github.io/WorkSpace-Plugins

# Dokumente
DOCUMENT_STORAGE_PROVIDER=local
DOCUMENT_MAX_FILE_SIZE_MB=25
DOCUMENT_ALLOW_ALL_MIME_TYPES=false

# App (optional override; normalerweise automatisch aus backend/package.json)
# APP_VERSION=1.0.0
