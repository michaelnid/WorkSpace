    "seed": "knex seed:run --knexfile knexfile.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/websocket": "^11.2.0",
    "@types/pdfmake": "^0.3.1",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "knex": "^3.1.0",
    "mysql2": "^3.12.0",
    "node-cron": "^4.2.1",
    "otpauth": "^9.3.6",
    "pdfmake": "^0.3.5",
    "qrcode": "^1.5.4",
    "unzipper": "^0.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/bcrypt": "^5.0.2",
