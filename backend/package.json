{
  "name": "mike-workspace-backend",
  "version": "1.19.1",
  "description": "MIKE WorkSpace - Backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
